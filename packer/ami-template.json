{
  "variables": {
    "aws_access_key": "{{env `AWS_ACCESS_KEY_ID`}}",
    "aws_secret_key": "{{env `AWS_SECRET_ACCESS_KEY`}}",
    "aws_region": "{{env `AWS_DEFAULT_REGION`}}",
    "ami_name": "java-app-{{timestamp}}"
  },
  "builders": [{
    "type": "amazon-ebs",
    "access_key": "{{user `aws_access_key`}}",
    "secret_key": "{{user `aws_secret_key`}}",
    "region": "{{user `aws_region`}}",
    "source_ami_filter": {
      "filters": {
        "virtualization-type": "hvm",
        "name": "amzn2-ami-hvm-*-x86_64-gp2",
        "root-device-type": "ebs"
      },
      "owners": ["137112412989"],
      "most_recent": true
    },
    "instance_type": "t2.micro",
    "ssh_username": "ec2-user",
    "ami_name": "{{user `ami_name`}}",
    "ami_description": "Java 17 Application with Spring Boot",
    "tags": {
      "Name": "JavaApp",
      "Version": "1.0.0",
      "BuiltBy": "Packer",
      "JavaVersion": "17"
    }
  }],
  "provisioners": [
    {
      "type": "shell",
      "inline": [
        "sleep 30",
        "sudo yum update -y",
        "sudo yum install -y amazon-linux-extras",
        "sudo amazon-linux-extras enable java-openjdk17",
        "sudo yum clean metadata",
        "sudo yum install -y java-17-openjdk",
        "sudo yum install -y git curl",
        "java -version"
      ]
    },
    {
      "type": "file",
      "source": "build/application.jar",
      "destination": "/home/ec2-user/application.jar"
    },
    {
      "type": "shell",
      "inline": [
        "sudo mkdir -p /opt/application",
        "sudo mv /home/ec2-user/application.jar /opt/application/",
        "sudo chmod +x /opt/application/application.jar",

        "cat > /tmp/application.service << 'EOF'",
        "[Unit]",
        "Description=Java Spring Boot Application",
        "After=network.target",
        "",
        "[Service]",
        "Type=simple",
        "User=ec2-user",
        "Group=ec2-user",
        "WorkingDirectory=/opt/application",
        "ExecStart=/usr/bin/java -jar /opt/application/application.jar",
        "Restart=on-failure",
        "RestartSec=10",
        "StandardOutput=journal",
        "StandardError=journal",
        "Environment='APP_VERSION={{timestamp}}'",
        "Environment='JAVA_OPTS=-Xmx512m -Xms256m'",
        "",
        "[Install]",
        "WantedBy=multi-user.target",
        "EOF",

        "sudo mv /tmp/application.service /etc/systemd/system/application.service",
        "sudo chmod 644 /etc/systemd/system/application.service",
        "sudo systemctl daemon-reload",
        "sudo systemctl enable application",
        "sudo systemctl start application",

        "sleep 10",
        "sudo systemctl status application"
      ]
    },
    {
      "type": "shell",
      "inline": [
        "cat > /home/ec2-user/health-check.sh << 'EOF'",
        "#!/bin/bash",
        "if curl -f http://localhost:8080/health; then",
        "  echo 'Application is healthy'",
        "  exit 0",
        "else",
        "  echo 'Application is not healthy'",
        "  exit 1",
        "fi",
        "EOF",
        "chmod +x /home/ec2-user/health-check.sh",

        "cat > /home/ec2-user/application-logs.sh << 'EOF'",
        "#!/bin/bash",
        "sudo journalctl -u application -f",
        "EOF",
        "chmod +x /home/ec2-user/application-logs.sh"
      ]
    }
  ],
  "post-processors": [
    {
      "type": "manifest",
      "output": "manifest.json",
      "strip_path": true
    }
  ]
}